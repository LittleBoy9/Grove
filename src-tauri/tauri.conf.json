{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Grove",
  "version": "0.1.0",
  "identifier": "com.sounakdas.grove",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Grove",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVCQkY4MDYwMjM1RTRDMUMKUldRY1RGNGpZSUMvNjlyUmtGRCtXanRpVG5WTFVxem1oNHZNRERpc2poQmRCOHM3bkx2cUl4bVQK",
      "endpoints": [
        "https://github.com/LittleBoy9/Grove/releases/latest/download/latest.json"
      ]
    }
  }
}
